{
  "name": "selfmanaged",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && npm run dev",
    "build": "tsc -b && vite build && cd server && npm run build",
    "build:electron": "npm run build && cd electron && npm run build",
    "start:prod": "npm run build && cross-env DB_FILE=data.db PORT=3001 node server/dist/index.js",
    "dev:mobile": "vite --config apps/mobile/vite.config.ts",
    "build:mobile": "vite build --config apps/mobile/vite.config.ts",
    "db:seed-dev": "node scripts/seed-dev-db.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "marked": "^18.0.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
